{
  "expo": {
    "name": "Hábitos Saludables",
    "slug": "habitos-saludables",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E5F9E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habitossaludables.app",
      "infoPlist": {
        "NSContactsUsageDescription": "Para encontrar amigos que usan la app.",
        "NSCameraUsageDescription": "Para compartir tus logros en fotos.",
        "NSMicrophoneUsageDescription": "Para enviar mensajes de voz.",
        "NSPhotoLibraryUsageDescription": "Para compartir imágenes de tus logros.",
        "NSCalendarsUsageDescription": "Para agregar tus hábitos al calendario."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E5F9E"
      },
      "package": "com.habitossaludables.app",
      "permissions": [
        "READ_CONTACTS", "CAMERA", "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE",
        "READ_CALENDAR", "WRITE_CALENDAR", "VIBRATE"
      ]
    },
    "plugins": [
      ["expo-notifications", { "color": "#1E5F9E" }],
      "expo-contacts",
      "expo-calendar"
    ],
    "extra": {
      "supabaseUrl": "https://usqugtxeynkozlobeojt.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVzcXVndHhleW5rb3psb2Jlb2p0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzEwOTYxMzAsImV4cCI6MjA4NjY3MjEzMH0.zs4XiF8AgcE-l3ebtaxvoN7V9rf-6MHWNxMThiQUXKE"
    }
  }
}
