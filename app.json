{
  "expo": {
    "name": "Hábitos Saludables",
    "slug": "habitos-saludables",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E5F9E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habitossaludables.app",
      "infoPlist": {
        "NSContactsUsageDescription": "Necesitamos acceso a tus contactos para encontrar amigos que usen la app.",
        "NSCameraUsageDescription": "Para tomar fotos y compartir tus logros.",
        "NSMicrophoneUsageDescription": "Para enviar mensajes de voz.",
        "NSPhotoLibraryUsageDescription": "Para compartir imágenes de tus logros.",
        "NSCalendarsUsageDescription": "Para agregar tus hábitos al calendario."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E5F9E"
      },
      "package": "com.habitossaludables.app",
      "permissions": [
        "READ_CONTACTS",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1E5F9E"
        }
      ],
      "expo-contacts",
      "expo-calendar"
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "anthropicApiKey": ""
    }
  }
}
